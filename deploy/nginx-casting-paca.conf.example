server {
    listen 80;
    server_name casting-paca.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name casting-paca.example.com;

    ssl_certificate /etc/letsencrypt/live/casting-paca.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/casting-paca.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    root /var/lib/veillecasting/public;
    index index.html;

    access_log /var/log/nginx/casting-paca.access.log;
    error_log /var/log/nginx/casting-paca.error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
